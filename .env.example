API_KEY=your-api-key
BASE_URL=https://ark.cn-beijing.volces.com/api/v3
MODEL=deepseek-v4-flash-260425

# Optional. Prefer this when you have a local sentence-transformers model.
# When set, detection uses this local embedding model before remote embedding.
# LOCAL_EMBEDDING_MODEL_PATH=F:/hf_cache/model

# Optional. Use remote embedding when your provider supports /embeddings.
# Leave unset to use the local hash embedding fallback.
# EMBEDDING_MODEL=your-embedding-model
# EMBEDDING_MAX_WORKERS=4

# Optional. Use these only when embedding uses a different provider.
# If omitted, embedding falls back to API_KEY and BASE_URL.
# EMBEDDING_API_KEY=your-embedding-api-key
# EMBEDDING_BASE_URL=https://your-embedding-provider.example.com/v1
